# Copy to `.env` in this folder (`server/.env`) and fill in values.
# Never commit `.env`.

# Required for JWT auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB (optional — server falls back to in-memory store if unreachable)
MONGO_URI=mongodb://127.0.0.1:27017/glow_wellness
# Alias supported by server.js if you already use this name elsewhere:
# MONGODB_URI=mongodb://127.0.0.1:27017/glow_wellness

PORT=8081
NODE_ENV=development
# Production: comma-separated frontend URLs for CORS (e.g. https://your-app.netlify.app)
# CORS_ORIGIN=

# Google Sign-In — OAuth 2.0 Client ID(s) used by verifyIdToken on the server.
# Use your **Web application** client ID (.apps.googleusercontent.com).
#
# Checklist (web: use glow_mobile/run_web_chrome.ps1 for a fixed port):
# - OAuth client type = **Web application** (same ID here, index.html, Console).
# - Authorized JavaScript origins: add **http://localhost** AND **http://localhost:7357** (match --web-port).
# - Authorized redirect URIs: **http://localhost:7357**
# - Restart Node after changing GOOGLE_CLIENT_ID.
# - If sign-in errors mention People API, enable it at:
#   https://console.cloud.google.com/apis/library/people.googleapis.com
#   (Glow web sign-in uses email scope only; enable People API only if you still see that error.)
#
# For Web + Android, comma-separate: id1.apps.googleusercontent.com,id2.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Dr. Najaat (chat) — OpenAI when set; else Gemini when GEMINI_API_KEY is set; else wellness snippets only.
# Variable name must be exactly OPENAI_API_KEY (not OPEN_API_KEY).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Expert AMA — set keys for answering questions & creating sessions (keep secret).
# Flutter app only needs JWT for asking questions; experts use API tools with these headers.
AMA_EXPERT_KEY=change-me-expert-ama-key
AMA_ADMIN_KEY=change-me-admin-ama-key
